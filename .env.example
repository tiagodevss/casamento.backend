NODE_ENV=development
PORT=3000

# postgresql://<user>:<password>@<host>:5432/<db>
DATABASE_URL=postgresql://casamento:casamento@localhost:5432/casamento

JWT_SECRET=change-me-to-a-long-random-string

ABACATEPAY_API_KEY=your-abacatepay-api-key
ABACATEPAY_WEBHOOK_SECRET=your-abacatepay-webhook-secret
ABACATEPAY_BASE_URL=https://api.abacatepay.com/v2

# Comma-separated list of origins allowed to call this API
CORS_ORIGIN=http://localhost:5173

# Directory for uploaded gift images (relative to backend root or absolute)
UPLOADS_DIR=./uploads

# Used once by `npm run prisma:seed`, not read by the running app afterwards
ADMIN1_EMAIL=tiago@example.com
ADMIN1_PASSWORD=change-me
ADMIN2_EMAIL=gabriela@example.com
ADMIN2_PASSWORD=change-me
